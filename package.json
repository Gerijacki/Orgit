{
  "name": "orgit",
  "version": "0.1.0",
  "description": "Autonomous repository evolution engine powered by Claude Code.",
  "keywords": [
    "ai",
    "llm",
    "claude",
    "claude-code",
    "anthropic",
    "automation",
    "developer-tools",
    "repository",
    "refactoring",
    "architecture",
    "technical-debt",
    "code-quality",
    "software-engineering",
    "developer-productivity",
    "agentic",
    "autonomous-agents",
    "documentation",
    "cli"
  ],
  "homepage": "https://github.com/Gerijacki/Orgit#readme",
  "bugs": {
    "url": "https://github.com/Gerijacki/Orgit/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Gerijacki/Orgit.git"
  },
  "license": "MIT",
  "author": "Gerijacki",
  "type": "module",
  "packageManager": "pnpm@10.6.5",
  "bin": {
    "orgit": "dist/cli/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli/index.ts",
    "orgit": "tsx src/cli/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "cross-env ORGIT_E2E=1 vitest run"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@lancedb/lancedb": "^0.31.0",
    "commander": "^15.0.0",
    "execa": "^9.5.2",
    "fast-glob": "^3.3.3",
    "fastembed": "^2.1.0",
    "ignore": "^7.0.5",
    "ora": "^9.4.1",
    "picocolors": "^1.1.1",
    "simple-git": "^3.28.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.0",
    "@vitest/coverage-v8": "^4.1.10",
    "cross-env": "^10.1.0",
    "eslint": "^10.6.0",
    "prettier": "^3.5.0",
    "tsup": "^8.4.0",
    "tsx": "^4.20.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "onnxruntime-node",
      "@lancedb/lancedb"
    ]
  }
}
